# Cloudflare Pages headers.
# The build-time generated metadata images are emitted without a file
# extension, so force their MIME type or social scrapers reject them.
/opengraph-image
  Content-Type: image/png
/apple-icon
  Content-Type: image/png

# Long-lived caching for Next's hashed static assets.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
